{
    "type": "project",
    "name": "survos-sites/pgsc",
    "description": "Popup Galleries of San Cristobal",
    "license": "proprietary",
    "minimum-stability": "beta",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-curl": "*",
        "ext-gd": "*",
        "ext-iconv": "*",
        "ext-imagick": "*",
        "ext-intl": "*",
        "api-platform/doctrine-orm": "^4.3.5",
        "api-platform/symfony": "^4.3.5",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.5",
        "easycorp/easyadmin-bundle": "^5.0.8",
        "endroid/qr-code-bundle": "^7.0",
        "google/apiclient": "^2.19.3",
        "survos/field-bundle": "^2.4.1",
        "league/csv": "^9.28.0",
        "meilisearch/meilisearch-php": "dev-main",
        "nelmio/cors-bundle": "^2.6.1",
        "paragonie/sodium_compat": "^2.5",
        "phpdocumentor/reflection-docblock": "^5.0|^6.0.3",
        "phpstan/phpdoc-parser": "^2.3.2",
        "stof/doctrine-extensions-bundle": "^1.15.3",
        "survos/auth-bundle": "^2.4.1",
        "survos/babel-bundle": "^2.4.1",
        "survos/command-bundle": "^2.4.1",
        "survos/core-bundle": "^2.4.1",
        "survos/deployment-bundle": "^2.4.1",
        "survos/ez-bundle": "^2.4.1",
        "survos/flickr-bundle": "^2.4.1",
        "survos/geoapify-bundle": "^2.4.1",
        "survos/google-sheets-bundle": "2.0.83",
        "survos/imgproxy-bundle": "^2.4.1",
        "survos/js-twig-bundle": "^2.4.1",
        "survos/media-bundle": "^2.4.1",
        "survos/meili-bundle": "^2.4.1",
        "survos/simple-datatables-bundle": "^2.4.1",
        "survos/state-bundle": "^2.4.1",
        "survos/tabler-bundle": "^2.4.1",
        "symfony/asset": "^8.1",
        "symfony/asset-mapper": "^8.1",
        "symfony/console": "^8.1",
        "symfony/doctrine-messenger": "^8.1",
        "symfony/dotenv": "^8.1",
        "symfony/expression-language": "^8.1",
        "symfony/flex": "^2.10",
        "symfony/form": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/http-client": "^8.1",
        "symfony/intl": "^8.1",
        "symfony/mailer": "^8.1",
        "symfony/mime": "^8.1",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/notifier": "^8.1",
        "symfony/object-mapper": "^8.1",
        "symfony/process": "^8.1",
        "symfony/property-access": "^8.1",
        "symfony/property-info": "^8.1",
        "symfony/runtime": "^8.1",
        "symfony/security-bundle": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/stimulus-bundle": "^3.0",
        "symfony/string": "^8.1",
        "symfony/translation": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/ux-icons": "^3.0",
        "symfony/ux-leaflet-map": "^3.0",
        "symfony/ux-map": "^3.0",
        "symfony/validator": "^8.1",
        "symfony/web-link": "^8.1",
        "symfony/workflow": "^8.1",
        "symfony/yaml": "^8.1",
        "symfonycasts/verify-email-bundle": "^1.18.0",
        "twig/extra-bundle": "^3.24.0",
        "twig/twig": "^3.25.0",
        "vich/uploader-bundle": ">=2.9.2"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "endroid/installer": true,
            "php-http/discovery": true,
            "survos/installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "php -d memory_limit=512M bin/console cache:clear",
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "php -d memory_limit=512M bin/console cache:clear",
            "@auto-scripts"
        ],
        "geocode": "bin/console workflow:iterate App\\\\Entity\\\\Location --transition=geocode --marking=new -vv\n"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "endpoint": [
                "https://api.github.com/repos/agence-adeliom/symfony-recipes/contents/index.json?ref=flex/main",
                "flex://defaults"
            ],
            "allow-contrib": true,
            "require": "^8.1"
        }
    },
    "require-dev": {
        "bluemmb/faker-picsum-photos-provider": "^2.0",
        "dbrekelmans/bdi": "^1.4.1",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "jzonta/faker-restaurant": "^2.0.1",
        "pelmered/fake-car": "^2.1",
        "phpstan/phpstan": "^2.1.55",
        "phpunit/phpunit": "^13.1.10",
        "survos/code-bundle": "^2.4.1",
        "survos/crawler-bundle": "^2.4.1",
        "survos/doc-bundle": "^2.4.1",
        "symfony/browser-kit": "^8.1",
        "symfony/css-selector": "^8.1",
        "symfony/debug-bundle": "^8.1",
        "symfony/maker-bundle": "^1.67.0",
        "symfony/panther": "^2.4",
        "symfony/stopwatch": "^8.1",
        "symfony/web-profiler-bundle": "^8.1",
        "zenstruck/browser": "^1.10.0",
        "zenstruck/console-test": "^1.8",
        "zenstruck/foundry": "^2.10"
    },
    "repositories": {
        "behaviors": {
            "type": "vcs",
            "url": "git@github.com:tacman/DoctrineBehaviors.git"
        }
    }
}
