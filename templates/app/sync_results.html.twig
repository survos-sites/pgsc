{% extends 'base.html.twig' %}

{% block title %}Sync results{% endblock %}

{% block body %}
<div class="container mt-4" style="max-width: 720px">

    <h2>Sync results</h2>

    {% if error %}
    <div class="alert alert-danger">
        <strong>Sync failed:</strong> {{ error }}
        {% if 'does not exist' in error and 'private_key' in error %}
        <div class="mt-2 small text-muted">
            The <code>JSON_AUTH</code> environment variable on the server may have mangled newlines in the private key.
            Run: <code>dokku config:set pgsc JSON_AUTH="$(cat google-credentials.json)"</code>
        </div>
        {% endif %}
    </div>
    {% endif %}

    <div class="row g-3 mb-4">
        <div class="col-auto">
            <div class="card text-center px-4 py-3">
                <div class="fs-2 fw-bold">{{ counts.artists }}</div>
                <div class="text-muted small">artists</div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card text-center px-4 py-3">
                <div class="fs-2 fw-bold">{{ counts.locations }}</div>
                <div class="text-muted small">locations</div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card text-center px-4 py-3">
                <div class="fs-2 fw-bold">{{ counts.obras }}</div>
                <div class="text-muted small">obras</div>
            </div>
        </div>
        {% if counts.skipped %}
        <div class="col-auto">
            <div class="card text-center px-4 py-3">
                <div class="fs-2 fw-bold text-muted">{{ counts.skipped|length }}</div>
                <div class="text-muted small">skipped</div>
            </div>
        </div>
        {% endif %}
    </div>

    {% if counts.warnings %}
    <div class="card border-warning mb-4">
        <div class="card-header bg-warning-subtle fw-semibold">
            ⚠️ {{ counts.warnings|length }} issue{{ counts.warnings|length > 1 ? 's' : '' }} — fix in the spreadsheet and re-sync
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sheet</th>
                        <th>Row</th>
                        <th>Obra</th>
                        <th>Problem</th>
                    </tr>
                </thead>
                <tbody>
                    {% for w in counts.warnings %}
                    <tr>
                        <td><code>{{ w.sheet }}</code></td>
                        <td class="text-muted">{{ w.row }}</td>
                        <td><code>{{ w.obra }}</code></td>
                        <td>{{ w.message }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% else %}
    <div class="alert alert-success">All rows synced successfully — no issues found.</div>
    {% endif %}

    <div class="d-flex gap-2">
        <a href="{{ spreadsheetUrl }}" target="_blank" class="btn btn-outline-success">
            📊 Open spreadsheet
        </a>
        <a href="{{ path('app_sync') }}" class="btn btn-outline-primary">
            🔄 Re-sync
        </a>
        <a href="{{ path('print_labels_config', {shortClass: 'obra'}) }}" class="btn btn-primary">
            🖨️ Print obra labels
        </a>
    </div>

</div>
{% endblock %}
