{% extends 'base.html.twig' %}

{% block title %}Print {{ shortClass }} labels{% endblock %}

{% block body %}
<div class="container mt-4" style="max-width: 560px">
    <h2>Print {{ shortClass }} labels</h2>

    <div class="d-flex gap-3 mb-4">
        {% if spreadsheetUrl %}
        <a href="{{ spreadsheetUrl }}" target="_blank" class="btn btn-outline-success btn-sm">
            📊 Open spreadsheet
        </a>
        {% endif %}
        <a href="{{ syncUrl }}" class="btn btn-outline-primary btn-sm">
            🔄 Sync from spreadsheet
        </a>
    </div>

    {{ form_start(form) }}
        {% if form.exhibition is defined %}
            {{ form_row(form.exhibition) }}
        {% endif %}
        {{ form_row(form.showQrCode) }}
        <div class="mt-3">
            {{ form_row(form.print) }}
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
